<UserControl
    x:Class="GraphEditor.Views.NodeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="clr-namespace:GraphEditor.Behaviors"
    xmlns:constants="clr-namespace:GraphEditor.Constants"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:GraphEditor.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Border>
        <i:Interaction.Behaviors>
            <b:NoClickPropagationBehavior />
        </i:Interaction.Behaviors>

        <Grid Width="{x:Static constants:UIConstants.NodeSize}" Height="{x:Static constants:UIConstants.NodeSize}">

            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseLeftButtonDown">
                    <i:InvokeCommandAction Command="{Binding OnClick}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>

            <Ellipse
                Width="{x:Static constants:UIConstants.NodeSize}"
                Height="{x:Static constants:UIConstants.NodeSize}"
                Fill="White">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">

                        <Setter Property="Stroke" Value="Black" />
                        <Setter Property="StrokeThickness" Value="1" />

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                <Setter Property="Stroke" Value="Black" />
                                <Setter Property="StrokeThickness" Value="1" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="Red" />
                                <Setter Property="StrokeThickness" Value="3" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>


            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Text="{Binding Number}" />
        </Grid>
    </Border>
</UserControl>