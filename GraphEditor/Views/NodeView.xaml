<UserControl
    x:Class="GraphEditor.Views.NodeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:constants="clr-namespace:GraphEditor.Constants"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GraphEditor.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Width="{x:Static constants:UIConstants.NodeSize}" Height="{x:Static constants:UIConstants.NodeSize}">
        <Ellipse
            Fill="White"
            Stroke="Black"
            StrokeThickness="1" />

        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontWeight="Bold"
            Text="{Binding Number}" />
    </Grid>
</UserControl>