<UserControl
    x:Class="GraphEditor.Views.GraphHistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:constants="clr-namespace:GraphEditor.Constants"
    xmlns:conv="clr-namespace:GraphEditor.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GraphEditor.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:CenterOffsetConverter x:Key="CenterOffsetConverter" />
    </UserControl.Resources>
    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="200" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Border BorderBrush="Black" BorderThickness="1">
                <Grid>
                    <ItemsControl IsHitTestVisible="False" ItemsSource="{Binding Edges}">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <local:ReadOnlyEdgeView />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                    <ItemsControl Background="Transparent" ItemsSource="{Binding Nodes}">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Canvas.Left">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource CenterOffsetConverter}">
                                            <Binding Path="Position.X" />
                                            <Binding Source="{x:Static constants:UIConstants.NodeSize}" />
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Canvas.Top">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource CenterOffsetConverter}">
                                            <Binding Path="Position.Y" />
                                            <Binding Source="{x:Static constants:UIConstants.NodeSize}" />
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <local:ReadOnlyNodeView />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Column="1">
            <Border
                Padding="12"
                Background="#F5F5F5"
                CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="10" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="5"
                        Content="Previous"
                        FontSize="14"
                        Foreground="Gray"
                        Command="{Binding PreviousCommand}" />

                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="5"
                        Content="Next"
                        FontSize="14"
                        Foreground="Gray"
                        Command="{Binding NextCommand}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>