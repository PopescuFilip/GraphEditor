<Window
    x:Class="GraphEditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GraphEditor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:GraphEditor.Views"
    xmlns:vms="clr-namespace:GraphEditor.ViewModels"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Grid>
        <Grid.Resources>
            <DataTemplate DataType="{x:Type vms:GraphViewModel}">
                <views:MainView />
            </DataTemplate>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="20" />
            <RowDefinition Height="430" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Menu>
                <MenuItem Header="File">
                    <MenuItem Command="{Binding NewGraph}" Header="New Graph" />
                    <MenuItem Command="{Binding Save}" Header="Save" />
                    <MenuItem Command="{Binding Open}" Header="Open" />
                </MenuItem>
                <MenuItem Header="Edit">
                    <MenuItem Command="{Binding EditEdges }" Header="Edges" />
                </MenuItem>
            </Menu>
        </Grid>
        <Grid Row="1">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Grid>
    </Grid>
</Window>
